#!/usr/bin/env bash
set -euo pipefail

subcommand=$1
shift

# Use xargs instead find -exec to pass exit status.

# shellcheck disable=SC2016
find packages \
-type d \
-not -path 'packages/dev-shared' \
-maxdepth 1 \
-mindepth 1 \
-print0 \
| xargs -0 -P 1 -I {} sh -c '
package_dir=$1
shift

cd "$package_dir"
uv run poe "$@"
' sh {} "$subcommand" "$@"
